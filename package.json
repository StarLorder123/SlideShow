{
  "name": "slideshow",
  "displayName": "SlideShow",
  "description": "Live-preview and export Markdown as stunning web-based slides. Built for developers who prefer code over PowerPoint",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md2slide.showPreview",
        "title": "MD2Slide: Open Presentation Preview",
        "icon": "$(screen-full)"
      },
      {
        "command": "md2slide.exportHtml",
        "title": "MD2Slide: Export to Standalone HTML"
      },
      {
        "command": "md2slide.toggleOverview",
        "title": "MD2Slide: Toggle Slide Overview"
      },
      {
        "command": "md2slide.outline.gotoSlide",
        "title": "Go to Slide",
        "icon": "$(go-to-file)"
      },
      {
        "command": "md2slide.refreshOutline",
        "title": "MD2Slide: Refresh Outline",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "md2slide.showPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "md2slide.refreshOutline",
          "when": "view == md2slideOutline",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "md2slide.toggleOverview",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "md2slide.previewActive"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md2slide",
          "title": "MD2Slide",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "md2slide": [
        {
          "id": "md2slideOutline",
          "name": "Slides Outline",
          "when": "md2slide.previewActive"
        }
      ]
    },
    "configuration": {
      "title": "Markdown to Slide",
      "properties": {
        "md2slide.theme": {
          "type": "string",
          "default": "black",
          "enum": ["black", "white", "league", "beige", "night", "serif", "simple"],
          "description": "Reveal.js visual theme."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:tsc": "tsc --watch --noEmit",
    "watch:esbuild": "node esbuild.js --watch",
    "watch-tests": "tsc --watch --noEmit",
    "package": "tsc --noEmit && node esbuild.js --production"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/markdown-it": "^14.1.0",
    "@types/vscode": "^1.94.0",
    "esbuild": "^0.23.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.4"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
